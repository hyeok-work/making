  function renderPickStep(opts){
    var picked = new Set();
    var stepStart = Date.now();
    var toggleCount = 0;

    var html = '';
    html += '<div class="eyebrow ' + (opts.eyebrowClass||'') + '">' + opts.eyebrowText + '</div>';
    html += '<h2 class="step-title">' + opts.titleHtml + '</h2>';
    html += '<hr class="rule" />';
    if(opts.desc){ html += '<p class="desc">' + opts.desc + '</p>'; }
    html += '<div class="counter-bar">';
    html += '<div class="counter ' + (opts.chipVariant==='wine' ? 'is-negative':'') + '" id="counterEl">' + opts.counterLabel + ' <b id="counterNum">0</b> / ' + opts.target + '</div>';
    html += '<div class="helper-msg" id="helperMsg"></div>';
    html += '</div>';
    html += '<div class="chip-grid" id="chipGrid"></div>';
    html += '<div class="actions">';
    html += renderDots();
    html += '<button class="btn btn-primary" id="nextBtn" disabled>' + (opts.nextLabel || '다음으로') + '</button>';
    html += '</div>';

    app.innerHTML = html;

    var grid = document.getElementById('chipGrid');
    var counterNum = document.getElementById('counterNum');
    var helperMsg = document.getElementById('helperMsg');
    var nextBtn = document.getElementById('nextBtn');

    opts.list.forEach(function(word){
      var chip = document.createElement('button');
      chip.type = 'button';
      var cls = 'chip';
      if(opts.mode === 'remove') cls += ' chip--remove';
      if(opts.chipVariant === 'wine' && opts.mode !== 'remove') cls += ' chip--wine';
      chip.className = cls;
      chip.textContent = word;
      chip.setAttribute('aria-pressed','false');
      chip.addEventListener('click', function(){
        if(picked.has(word)){
          picked.delete(word);
          chip.classList.remove('chip--active');
          chip.setAttribute('aria-pressed','false');
          toggleCount++;
        } else {
          if(picked.size >= opts.target){
            helperMsg.textContent = '이미 ' + opts.target + '개를 골랐어요. 다른 단어를 먼저 내려놓아 주세요.';
            return;
          }
          picked.add(word);
          chip.classList.add('chip--active');
          chip.setAttribute('aria-pressed','true');
          toggleCount++;
        }
        helperMsg.textContent = '';
        counterNum.textContent = picked.size;
        nextBtn.disabled = picked.size !== opts.target;
      });
      grid.appendChild(chip);
    });

    nextBtn.addEventListener('click', function(){
      var pickedArr = Array.from(picked);
      var result;
      if(opts.mode === 'keep'){
        result = pickedArr;
      } else {
        result = opts.list.filter(function(w){ return !picked.has(w); });
      }
      if(opts.stageKey){
        state.journeyLog[opts.stageKey] = { duration_ms: Date.now()-stepStart, total_toggles: toggleCount };
      }
      opts.onDone(result, pickedArr);
    });
  }

