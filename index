  function buildStageSummaries(){
    var order = ['positive_select','positive_drop_1','positive_drop_2','negative_select','negative_drop','opposite_select','final_select'];
    var list = order.map(function(key){
      var entry = state.journeyLog[key] || { duration_ms: 0, total_toggles: 0 };
      return { stage: key, duration_ms: entry.duration_ms, total_toggles: entry.total_toggles };
    });
    list.push({ stage: 'result', duration_ms: null, total_toggles: 0 });
    return list;
  }

  function findMostHesitant(summaries){
    var measured = summaries.filter(function(s){ return s.stage !== 'result'; });
    var maxToggle = measured.reduce(function(a,b){ return b.total_toggles > a.total_toggles ? b : a; }, measured[0]);
    var maxDuration = measured.reduce(function(a,b){ return b.duration_ms > a.duration_ms ? b : a; }, measured[0]);
    return { maxToggle: maxToggle, maxDuration: maxDuration };
  }

