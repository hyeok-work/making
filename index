<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>노동이사, 나는 어떤 사람인가 — 가치 여정</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Song+Myung&family=Noto+Serif+KR:wght@500;700;900&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#1B2A4A;
    --navy-soft:#33476f;
    --cream:#F6F1E7;
    --cream-deep:#EFE7D6;
    --terracotta:#C75B39;
    --terracotta-soft:#e2a98f;
    --gold:#D9A441;
    --wine:#6E3B3B;
    --wine-soft:#caa3a3;
    --charcoal:#2B2620;
    --line:#DCD1B4;
    --shadow: 0 18px 40px -22px rgba(27,42,74,0.45);
    --radius: 18px;
    --maxw: 660px;
  }

  *{ box-sizing:border-box; }

  html,body{
    margin:0; padding:0;
    background:
      radial-gradient(ellipse at top, #fffdf7 0%, var(--cream) 55%, var(--cream-deep) 100%);
    color:var(--charcoal);
    font-family:'Noto Sans KR', sans-serif;
    min-height:100%;
  }

  body{
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:32px 18px 60px;
  }

  .wrap{
    width:100%;
    max-width:var(--maxw);
  }

  /* ---------- top bar ---------- */
  .topbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:18px;
    gap:12px;
  }
  .brand{
    font-family:'Noto Serif KR', serif;
    font-weight:900;
    font-size:15px;
    letter-spacing:0.04em;
    color:var(--navy);
    display:flex;
    align-items:center;
    gap:8px;
  }
  .brand small{
    font-family:'Noto Sans KR', sans-serif;
    font-weight:400;
    font-size:11px;
    color:#8a8170;
    letter-spacing:0;
  }
  .reset-link{
    background:none;
    border:none;
    font-family:'Noto Sans KR', sans-serif;
    font-size:12px;
    color:#8a8170;
    text-decoration:underline;
    cursor:pointer;
    padding:4px 2px;
  }
  .reset-link:hover{ color:var(--terracotta); }

  /* ---------- chair signature ---------- */
  .chair-box{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:6px;
    margin:6px 0 22px;
  }
  .chair-icon{
    width:64px;
    height:auto;
    transition:filter .6s ease;
  }
  .chair-caption{
    font-size:11px;
    color:#8a8170;
    letter-spacing:0.04em;
  }
  .chair-caption strong{ color:var(--navy); }

  /* ---------- card ---------- */
  .card{
    background:#fffdf8;
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:32px 28px 28px;
    position:relative;
    overflow:hidden;
  }
  .card::before{
    content:"";
    position:absolute;
    top:0; left:0; right:0;
    height:5px;
    background:linear-gradient(90deg, var(--terracotta), var(--gold) 55%, var(--wine));
  }

  .eyebrow{
    font-size:12px;
    font-weight:700;
    letter-spacing:0.12em;
    color:var(--terracotta);
    text-transform:uppercase;
    margin-bottom:10px;
  }
  .eyebrow.is-negative{ color:var(--wine); }
  .eyebrow.is-final{ color:var(--gold); }

  h1.headline{
    font-family:'Song Myung', serif;
    font-weight:400;
    font-size:30px;
    line-height:1.35;
    color:var(--navy);
    margin:0 0 6px;
  }
  h2.step-title{
    font-family:'Noto Serif KR', serif;
    font-weight:900;
    font-size:21px;
    line-height:1.4;
    color:var(--navy);
    margin:0 0 8px;
  }
  .rule{
    width:46px; height:3px;
    background:var(--gold);
    border:none;
    margin:0 0 16px;
    border-radius:2px;
  }

  p.lede{
    font-size:14.5px;
    line-height:1.7;
    color:#564f42;
    margin:0 0 4px;
  }
  p.desc{
    font-size:13.5px;
    line-height:1.7;
    color:#76705f;
    margin:0 0 20px;
  }

  .meta-row{
    display:flex;
    gap:18px;
    flex-wrap:wrap;
    margin:18px 0 26px;
    font-size:12.5px;
    color:var(--navy);
  }
  .meta-row span{
    display:flex;
    align-items:center;
    gap:6px;
    background:var(--cream-deep);
    padding:6px 12px;
    border-radius:999px;
  }
  .meta-row b{ font-weight:700; }

  /* ---------- counter ---------- */
  .counter-bar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:14px;
    flex-wrap:wrap;
    gap:8px;
  }
  .counter{
    font-size:13px;
    font-weight:700;
    color:var(--navy);
    background:var(--cream-deep);
    padding:6px 14px;
    border-radius:999px;
  }
  .counter b{ color:var(--terracotta); font-size:15px; }
  .counter.is-negative b{ color:var(--wine); }
  .helper-msg{
    font-size:12.5px;
    color:#8a8170;
  }

  /* ---------- chip grid ---------- */
  .chip-grid{
    display:flex;
    flex-wrap:wrap;
    gap:9px;
    margin-bottom:24px;
  }
  .chip{
    font-family:'Noto Sans KR', sans-serif;
    font-size:13.5px;
    font-weight:500;
    color:var(--navy);
    background:#fff;
    border:1.4px solid var(--line);
    border-radius:999px;
    padding:9px 16px;
    cursor:pointer;
    transition:background .18s ease, color .18s ease, border-color .18s ease, transform .12s ease;
  }
  .chip:hover{ border-color:var(--terracotta); transform:translateY(-1px); }
  .chip:focus-visible{ outline:3px solid var(--gold); outline-offset:2px; }
  .chip--active{
    background:var(--navy);
    border-color:var(--navy);
    color:#fff;
  }
  .chip--active:hover{ border-color:var(--navy); }

  /* remove-mode visual: selected = marked to let go */
  .chip--remove.chip--active{
    background:#fff;
    border-color:var(--wine);
    color:var(--wine);
    text-decoration:line-through;
    text-decoration-color:var(--wine);
  }

  /* negative-pool select mode tint */
  .chip--wine.chip--active{
    background:var(--wine);
    border-color:var(--wine);
  }

  /* ---------- final step two-group ---------- */
  .group-label{
    font-size:12px;
    font-weight:700;
    letter-spacing:0.06em;
    color:#8a8170;
    text-transform:uppercase;
    margin:18px 0 8px;
  }
  .group-label:first-of-type{ margin-top:0; }

  /* ---------- transition step ---------- */
  .trans-block{
    border:1px solid var(--line);
    border-radius:14px;
    padding:16px 16px 12px;
    margin-bottom:14px;
    background:#fffaf2;
  }
  .trans-block .from-word{
    font-size:13px;
    color:var(--wine);
    font-weight:700;
    margin-bottom:2px;
  }
  .trans-block .arrow-note{
    font-size:12px;
    color:#8a8170;
    margin-bottom:10px;
  }
  .trans-options{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
  }

  /* ---------- buttons ---------- */
  .actions{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:14px;
    margin-top:8px;
  }
  .btn{
    font-family:'Noto Sans KR', sans-serif;
    font-weight:700;
    font-size:14.5px;
    border:none;
    border-radius:999px;
    padding:13px 26px;
    cursor:pointer;
    transition:opacity .18s ease, transform .12s ease;
  }
  .btn:focus-visible{ outline:3px solid var(--gold); outline-offset:2px; }
  .btn-primary{
    background:var(--navy);
    color:#fff;
  }
  .btn-primary:disabled{
    background:#cfc8b6;
    color:#8a8170;
    cursor:not-allowed;
  }
  .btn-primary:not(:disabled):hover{ transform:translateY(-1px); }
  .btn-ghost{
    background:none;
    color:#8a8170;
    text-decoration:underline;
    padding:13px 6px;
  }

  .progress-dots{
    display:flex;
    gap:5px;
  }
  .progress-dots i{
    width:6px; height:6px;
    border-radius:50%;
    background:var(--line);
    display:block;
  }
  .progress-dots i.is-done{ background:var(--gold); }
  .progress-dots i.is-current{ background:var(--terracotta); }

  /* ---------- intro ---------- */
  .intro-cta{
    width:100%;
    margin-top:8px;
  }
  .intro-cta .btn-primary{ width:100%; padding:16px; font-size:15.5px; }

  .disclaimer{
    font-size:11.5px;
    color:#9a937f;
    line-height:1.6;
    margin-top:18px;
    border-top:1px dashed var(--line);
    padding-top:14px;
  }

  /* ---------- result ---------- */
  .value-cards{
    display:flex;
    flex-direction:column;
    gap:10px;
    margin:20px 0 26px;
  }
  .value-card{
    display:flex;
    align-items:baseline;
    gap:14px;
    background:linear-gradient(100deg, var(--cream-deep), #fffdf8);
    border:1px solid var(--line);
    border-left:4px solid var(--gold);
    border-radius:12px;
    padding:14px 18px;
  }
  .value-card .num{
    font-family:'Noto Serif KR', serif;
    font-weight:900;
    font-size:13px;
    color:var(--gold);
  }
  .value-card .word{
    font-family:'Noto Serif KR', serif;
    font-weight:700;
    font-size:19px;
    color:var(--navy);
  }

  .prompt-box{
    margin-top:8px;
  }
  .prompt-box label{
    display:block;
    font-size:12.5px;
    font-weight:700;
    color:var(--navy);
    margin-bottom:8px;
  }
  textarea.prompt-text{
    width:100%;
    min-height:280px;
    resize:vertical;
    font-family:'Noto Sans KR', sans-serif;
    font-size:12.8px;
    line-height:1.65;
    color:#564f42;
    background:#fff;
    border:1px solid var(--line);
    border-radius:12px;
    padding:14px;
  }
  .copy-row{
    display:flex;
    align-items:center;
    gap:12px;
    margin-top:10px;
  }
  .copy-status{
    font-size:12.5px;
    color:var(--gold);
    font-weight:700;
    opacity:0;
    transition:opacity .2s ease;
  }
  .copy-status.is-visible{ opacity:1; }

  .result-actions{
    margin-top:26px;
    display:flex;
    gap:12px;
    flex-wrap:wrap;
  }

  footer.credit{
    text-align:center;
    font-size:11px;
    color:#a8a08c;
    margin-top:26px;
    letter-spacing:0.02em;
    line-height:1.7;
  }

  @media (max-width:480px){
    .card{ padding:24px 18px 22px; }
    h1.headline{ font-size:25px; }
    h2.step-title{ font-size:18px; }
    .actions{ flex-direction:column-reverse; align-items:stretch; }
    .actions .btn{ width:100%; text-align:center; }
  }

  @media (prefers-reduced-motion: reduce){
    *{ transition:none !important; animation:none !important; }
  }
</style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">노동이사 가치 여정 <small>공공상생연대기금</small></div>
      <button class="reset-link" id="resetBtn" type="button">처음부터 다시</button>
    </div>

    <div class="chair-box">
      <svg class="chair-icon" viewBox="0 0 200 240" aria-hidden="true">
        <defs>
          <clipPath id="chairFillClip">
            <rect id="fillRect" x="0" y="240" width="200" height="0" />
          </clipPath>
        </defs>
        <g id="chairFilled" clip-path="url(#chairFillClip)">
          <rect x="70" y="20" width="60" height="90" rx="6" fill="var(--gold)"/>
          <rect x="40" y="110" width="120" height="24" rx="4" fill="var(--gold)"/>
          <line x1="55" y1="134" x2="50" y2="220" stroke="var(--gold)" stroke-width="10" stroke-linecap="round"/>
          <line x1="145" y1="134" x2="150" y2="220" stroke="var(--gold)" stroke-width="10" stroke-linecap="round"/>
          <line x1="70" y1="134" x2="68" y2="220" stroke="var(--gold)" stroke-width="10" stroke-linecap="round"/>
          <line x1="130" y1="134" x2="132" y2="220" stroke="var(--gold)" stroke-width="10" stroke-linecap="round"/>
        </g>
        <g fill="none" stroke="var(--navy)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="70" y="20" width="60" height="90" rx="6"/>
          <rect x="40" y="110" width="120" height="24" rx="4"/>
          <line x1="55" y1="134" x2="50" y2="220"/>
