    }
    html += '</div>';

    html += '<div class="prompt-box">';
    html += '<label for="promptArea">AI 요약 프롬프트 — 복사해서 AI에게 붙여넣으면 네트워킹용 요약을 받을 수 있어요</label>';
    html += '<textarea class="prompt-text" id="promptArea" readonly></textarea>';
    html += '<div class="copy-row"><button class="btn btn-primary" id="copyBtn" type="button">복사하기</button><span class="copy-status" id="copyStatus">복사되었습니다</span></div>';
    html += '</div>';

    html += '<div class="result-actions">';
    html += '<button class="btn btn-ghost" id="restartBtn" type="button">처음부터 다시 해보기</button>';
    html += '</div>';

    html += '<p class="disclaimer">이 결과는 자기 성찰을 돕기 위한 참고 자료입니다. 노동이사 적격성을 공식적으로 평가·인증하는 도구가 아니므로, 실제 후보 검토나 선임 과정에서는 기관의 공식 절차와 기준을 따라주세요.</p>';

    app.innerHTML = html;

    var promptArea = document.getElementById('promptArea');
    promptArea.value = buildPrompt(state);

    document.getElementById('copyBtn').addEventListener('click', function(){
      var status = document.getElementById('copyStatus');
      function showStatus(){
        status.classList.add('is-visible');
        setTimeout(function(){ status.classList.remove('is-visible'); }, 1800);
      }
      if(navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(promptArea.value).then(showStatus).catch(function(){
          promptArea.select();
          document.execCommand('copy');
          showStatus();
        });
      } else {
        promptArea.select();
        document.execCommand('copy');
        showStatus();
      }
    });

    document.getElementById('restartBtn').addEventListener('click', resetAll);
  }

  /* ---------------------------------------------------------------
     라우터
  --------------------------------------------------------------- */
  function render(){
    var key = currentKey();
    if(key === 'intro') return renderIntro();
    if(key === 'p1') return renderP1();
    if(key === 'p2') return renderP2();
    if(key === 'p3') return renderP3();
    if(key === 'n1') return renderN1();
    if(key === 'n2') return renderN2();
    if(key === 't') return renderTransition();
    if(key === 'f') return renderFinal();
    if(key === 'result') return renderResult();
  }

  setProgress(0);
  render();
})();
</script>
</body>
